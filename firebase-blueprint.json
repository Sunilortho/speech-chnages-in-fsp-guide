{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's unique ID"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address"
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the user profile was created"
        }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "PracticeSession": {
      "title": "PracticeSession",
      "description": "A German Doctors Exam Prep practice session",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user who created the session"
        },
        "scenarioId": {
          "type": "string",
          "description": "The ID of the patient scenario"
        },
        "score": {
          "type": "number",
          "description": "The score achieved in the session"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the session was created"
        }
      },
      "required": ["userId", "scenarioId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "UserProfile" },
      "description": "User profiles"
    },
    "/practiceSessions/{sessionId}": {
      "schema": { "$ref": "PracticeSession" },
      "description": "Practice sessions for users"
    }
  }
}
